# Copy this file to .env or .env.local for local shell and docker compose use.
# Do not commit real credentials.

# Optional provider credentials and router endpoints
# Smart-layer credentials are only needed when PAPER_CHASER_ENABLE_AGENTIC=true
# and the matching PAPER_CHASER_AGENTIC_PROVIDER is selected.
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_PLANNER_DEPLOYMENT=
AZURE_OPENAI_SYNTHESIS_DEPLOYMENT=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
CORE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
OPENALEX_MAILTO=
SERPAPI_API_KEY=
GOVINFO_API_KEY=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=
ECOS_BASE_URL=https://ecos.fws.gov
SCHOLARAPI_API_KEY=

# Provider toggles
# Recommended balanced scholarly baseline: Semantic Scholar + OpenAlex +
# Crossref + Unpaywall. Enable ScholarAPI when you want explicit full-text/PDF
# retrieval, and keep SerpApi opt-in because it is a paid recall-recovery path.
PAPER_CHASER_ENABLE_CORE=false
PAPER_CHASER_ENABLE_SEMANTIC_SCHOLAR=true
PAPER_CHASER_ENABLE_OPENALEX=true
PAPER_CHASER_ENABLE_ARXIV=true
PAPER_CHASER_ENABLE_SERPAPI=false
PAPER_CHASER_ENABLE_CROSSREF=true
PAPER_CHASER_ENABLE_UNPAYWALL=true
PAPER_CHASER_ENABLE_ECOS=true
PAPER_CHASER_ENABLE_FEDERAL_REGISTER=true
PAPER_CHASER_ENABLE_GOVINFO_CFR=true
PAPER_CHASER_ENABLE_AGENTIC=false
PAPER_CHASER_ENABLE_SCHOLARAPI=false
PAPER_CHASER_TOOL_PROFILE=guided
# Keep this true on the guided surface so clients do not get baited into dead-end tool picks.
# Set PAPER_CHASER_TOOL_PROFILE=expert and PAPER_CHASER_HIDE_DISABLED_TOOLS=false only when you
# intentionally want the raw/provider-specific surface for operator workflows.
PAPER_CHASER_HIDE_DISABLED_TOOLS=true

# Enrichment provider runtime
CROSSREF_TIMEOUT_SECONDS=30
UNPAYWALL_TIMEOUT_SECONDS=30
ECOS_TIMEOUT_SECONDS=30
FEDERAL_REGISTER_TIMEOUT_SECONDS=30
GOVINFO_TIMEOUT_SECONDS=30
GOVINFO_DOCUMENT_TIMEOUT_SECONDS=60
GOVINFO_MAX_DOCUMENT_SIZE_MB=25
ECOS_DOCUMENT_TIMEOUT_SECONDS=60
ECOS_DOCUMENT_CONVERSION_TIMEOUT_SECONDS=60
ECOS_MAX_DOCUMENT_SIZE_MB=25
# Leave ECOS_VERIFY_TLS=true unless you are debugging a local trust-store issue.
# If ECOS is intercepted by a corporate proxy, prefer ECOS_CA_BUNDLE over
# disabling verification.
ECOS_VERIFY_TLS=true
ECOS_CA_BUNDLE=

# Optional broker override
PAPER_CHASER_PROVIDER_ORDER=

# Smart workflow configuration
PAPER_CHASER_AGENTIC_PROVIDER=openai
# Default planner/synthesis behavior depends on PAPER_CHASER_AGENTIC_PROVIDER:
# - openai: gpt-5.4-mini / gpt-5.4
# - azure-openai: same defaults unless AZURE_OPENAI_PLANNER_DEPLOYMENT /
#   AZURE_OPENAI_SYNTHESIS_DEPLOYMENT are set, in which case those deployment
#   names override the model vars.
# - anthropic: if these vars stay on the checked-in OpenAI defaults, runtime
#   swaps to claude-haiku-4-5 / claude-sonnet-4-6.
# - nvidia: if these vars stay on the checked-in OpenAI defaults, runtime swaps
#   to nvidia/nemotron-3-nano-30b-a3b /
#   nvidia/nemotron-3-super-120b-a12b.
# - google: if these vars stay on the checked-in OpenAI defaults, runtime swaps
#   to gemini-2.5-flash / gemini-2.5-pro.
# - mistral: if these vars stay on the checked-in OpenAI defaults, runtime swaps
#   to mistral-medium-latest / mistral-large-latest.
# - huggingface: if these vars stay on the checked-in OpenAI defaults, runtime
#   swaps to moonshotai/Kimi-K2.5 / moonshotai/Kimi-K2.5 and sends
#   those model IDs to HUGGINGFACE_BASE_URL. This path remains chat-only.
# - deterministic: no external LLM calls; selection metadata reports
#   deterministic planner/synthesizer names instead.
# NVIDIA_NIM_BASE_URL defaults to the hosted NVIDIA API Catalog endpoint.
# Change it only when you want to point at a self-hosted NIM base URL such as
# http://localhost:8000/v1.
PAPER_CHASER_PLANNER_MODEL=gpt-5.4-mini
PAPER_CHASER_SYNTHESIS_MODEL=gpt-5.4
# Embeddings stay disabled by default. When you enable them, the default
# embedding model is OpenAI-compatible and is used only by providers that
# support embeddings in this repo.
PAPER_CHASER_EMBEDDING_MODEL=text-embedding-3-large
PAPER_CHASER_DISABLE_EMBEDDINGS=true
PAPER_CHASER_AGENTIC_OPENAI_TIMEOUT_SECONDS=30
# Keep memory as the default backend for small saved result sets. Switch to
# faiss only when the runtime image includes the optional ai-faiss extra.
PAPER_CHASER_AGENTIC_INDEX_BACKEND=memory
PAPER_CHASER_SESSION_TTL_SECONDS=1800
PAPER_CHASER_ENABLE_AGENTIC_TRACE_LOG=false

# Local HTTP settings.
# PAPER_CHASER_TRANSPORT and PAPER_CHASER_HTTP_PATH affect both direct
# shell runs and docker compose. The compose image intentionally keeps its
# internal bind host and container port fixed at 0.0.0.0:8080.
# The application default is stdio. Override to streamable-http when running
# behind docker compose or a remote deployment.
PAPER_CHASER_TRANSPORT=stdio
PAPER_CHASER_HTTP_PATH=/mcp
PAPER_CHASER_HTTP_AUTH_TOKEN=
PAPER_CHASER_HTTP_AUTH_HEADER=authorization
PAPER_CHASER_ALLOWED_ORIGINS=

# docker compose publish settings
PAPER_CHASER_PUBLISHED_HOST=127.0.0.1
PAPER_CHASER_PUBLISHED_PORT=8000
