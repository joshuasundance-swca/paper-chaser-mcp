# Copy this file to .env or .env.local for local shell and docker compose use.
# Do not commit real credentials.

# Optional provider credentials
# OPENAI_API_KEY is only needed when SCHOLAR_SEARCH_ENABLE_AGENTIC=true and
# SCHOLAR_SEARCH_AGENTIC_PROVIDER=openai.
OPENAI_API_KEY=
CORE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
OPENALEX_MAILTO=
SERPAPI_API_KEY=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=
ECOS_BASE_URL=https://ecos.fws.gov

# Provider toggles
SCHOLAR_SEARCH_ENABLE_CORE=false
SCHOLAR_SEARCH_ENABLE_SEMANTIC_SCHOLAR=true
SCHOLAR_SEARCH_ENABLE_OPENALEX=true
SCHOLAR_SEARCH_ENABLE_ARXIV=true
SCHOLAR_SEARCH_ENABLE_SERPAPI=false
SCHOLAR_SEARCH_ENABLE_CROSSREF=true
SCHOLAR_SEARCH_ENABLE_UNPAYWALL=true
SCHOLAR_SEARCH_ENABLE_ECOS=true
SCHOLAR_SEARCH_ENABLE_AGENTIC=false

# Enrichment provider runtime
CROSSREF_TIMEOUT_SECONDS=30
UNPAYWALL_TIMEOUT_SECONDS=30
ECOS_TIMEOUT_SECONDS=30
ECOS_DOCUMENT_TIMEOUT_SECONDS=60
ECOS_MAX_DOCUMENT_SIZE_MB=25
# Leave ECOS_VERIFY_TLS=true unless you are debugging a local trust-store issue.
# If ECOS is intercepted by a corporate proxy, prefer ECOS_CA_BUNDLE over
# disabling verification.
ECOS_VERIFY_TLS=true
ECOS_CA_BUNDLE=

# Optional broker override
SCHOLAR_SEARCH_PROVIDER_ORDER=

# Smart workflow configuration
SCHOLAR_SEARCH_AGENTIC_PROVIDER=openai
# Planner stays on the lower-latency GPT-5.4 mini tier, while synthesis uses
# the larger GPT-5.4 model for answer quality.
SCHOLAR_SEARCH_PLANNER_MODEL=gpt-5.4-mini
SCHOLAR_SEARCH_SYNTHESIS_MODEL=gpt-5.4
SCHOLAR_SEARCH_EMBEDDING_MODEL=text-embedding-3-large
SCHOLAR_SEARCH_DISABLE_EMBEDDINGS=false
SCHOLAR_SEARCH_AGENTIC_OPENAI_TIMEOUT_SECONDS=30
# Keep memory as the default backend for small saved result sets. Switch to
# faiss only when the runtime image includes the optional ai-faiss extra.
SCHOLAR_SEARCH_AGENTIC_INDEX_BACKEND=memory
SCHOLAR_SEARCH_SESSION_TTL_SECONDS=1800
SCHOLAR_SEARCH_ENABLE_AGENTIC_TRACE_LOG=false

# Local HTTP settings.
# SCHOLAR_SEARCH_TRANSPORT and SCHOLAR_SEARCH_HTTP_PATH affect both direct
# shell runs and docker compose. The compose image intentionally keeps its
# internal bind host and container port fixed at 0.0.0.0:8080.
SCHOLAR_SEARCH_TRANSPORT=streamable-http
SCHOLAR_SEARCH_HTTP_PATH=/mcp
SCHOLAR_SEARCH_HTTP_AUTH_TOKEN=
SCHOLAR_SEARCH_HTTP_AUTH_HEADER=authorization
SCHOLAR_SEARCH_ALLOWED_ORIGINS=

# docker compose publish settings
SCHOLAR_SEARCH_PUBLISHED_HOST=127.0.0.1
SCHOLAR_SEARCH_PUBLISHED_PORT=8000
