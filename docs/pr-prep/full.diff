+def _runtime_provider_order(
+    *,
+    provider_order: list[SearchProvider] | None,
+    smart_provider_order: list[str],
+) -> list[str]:
+    return [
+        *(provider_order or []),
+        "openalex",
+        "scholarapi",
+        "crossref",
+        "unpaywall",
+        *smart_provider_order,
+        "ecos",
+        "federal_register",
+        "govinfo",
+    ]
