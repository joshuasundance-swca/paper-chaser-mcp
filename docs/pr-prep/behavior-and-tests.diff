+    if enrichments is not None:
+        for candidate in (
+            enrichments.crossref.url if enrichments.crossref is not None else None,
+            enrichments.openalex.url if enrichments.openalex is not None else None,
+        ):
+            if candidate:
+                return candidate
+    return paper.url
+
