+def _cfr_tokens(citation: str | None) -> set[str]:
+    if not citation:
+        return set()
+    return {token for token in re.findall(r"[a-z0-9]{2,}", citation.lower()) if token not in _CFR_DOC_TYPE_GENERIC}
+
