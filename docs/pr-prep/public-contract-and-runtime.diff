+        "openai",
+        "azure-openai",
+        "anthropic",
+        "nvidia",
+        "google",
+        "mistral",
+        "huggingface",
+    ]
+    configured_smart_provider: str | None = None
+    active_smart_provider: str | None = None
+    if agentic_runtime is not None and hasattr(agentic_runtime, "smart_provider_diagnostics"):
